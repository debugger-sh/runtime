{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 2 }, { "line": 6 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [
            { "line": 2, "verified": true },
            { "line": 6, "verified": true }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "${{thread}}" } // line 2 in foo
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.prefix": [{ "line": 6 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "${{thread}}" } // line 2 in foo (breakpoint collision)
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.prefix": [{ "line": 2 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.prefix": [{ "line": 3 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepIn",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" } // return to caller main
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.prefix": [{ "line": 7 }]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
