{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "main.cpp" },
        "breakpoints": [{ "line": 11 }, { "line": 2 }]
      }
    },
    {
      "type": "response",
      "body": {
        "breakpoints": {
          "$array.contains": [
            { "line": 11, "verified": true },
            { "line": 2, "verified": true }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "${{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "line": 11 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepOut",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "breakpoint", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "line": 2 }, { "line": 6 }, { "line": 11 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepOut",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "line": 7 }, { "line": 11 }],
          "$array.excludes": [{ "line": 2 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepOut",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "line": 12 }],
          "$array.excludes": [{ "line": 7 }]
        }
      }
    },
    {
      "type": "request",
      "command": "stepOut",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "event",
      "event": "stopped",
      "body": { "reason": "step", "threadId": "{{thread}}" }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": "{{thread}}" }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "line": 17 }],
          "$array.excludes": [{ "line": 12 }]
        }
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": "{{thread}}" }
    }
  ]
}
