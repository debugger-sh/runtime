{
  "steps": [
    {
      "type": "request",
      "command": "setBreakpoints",
      "arguments": {
        "source": { "path": "/main.c" },
        "breakpoints": [{ "line": 3 }]
      }
    },
    {
      "type": "request",
      "command": "configurationDone",
      "arguments": {}
    },
    {
      "type": "event",
      "event": "stopped",
      "body": {
        "reason": "breakpoint",
        "threadId": 1
      }
    },
    {
      "type": "request",
      "command": "stackTrace",
      "arguments": { "threadId": 1, "startFrame": 0, "levels": 20 }
    },
    {
      "type": "response",
      "body": {
        "stackFrames": {
          "$array.contains": [{ "id": 0, "name": "main" }]
        }
      }
    },
    {
      "type": "request",
      "command": "scopes",
      "arguments": { "frameId": 0 }
    },
    {
      "type": "response",
      "body": {
        "scopes": {
          "$array.contains": [
            {
              "name": "Locals",
              "variablesReference": "{{locals}}"
            }
          ]
        }
      }
    },
    {
      "type": "request",
      "command": "variables",
      "arguments": {
        "variablesReference": "{{locals}}"
      }
    },
    {
      "type": "response",
      "body": {
        "variables": [
          {
            "name": "x",
            "value": "1",
            "type": "int"
          }
        ]
      }
    },
    {
      "type": "request",
      "command": "continue",
      "arguments": { "threadId": 1 }
    }
  ]
}
